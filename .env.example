NODE_ENV=production
PORT=4000
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated list of allowed frontend origins.
# Example: https://your-frontend.netlify.app
CORS_ORIGIN=

# For Render persistent disks, use a path under /var/data.
# Example: /var/data/database.sqlite3
SQLITE_STORAGE=./storage/database.sqlite3